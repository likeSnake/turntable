<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F1EAEA"
    >

    <RelativeLayout
        android:id="@+id/random_title"
        android:layout_width="match_parent"
        android:background="#E8E3E3"
        android:layout_height="60dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_centerHorizontal="true"
            android:textColor="@color/black"
            android:text="Setting"/>
    </RelativeLayout>



    <LinearLayout
        android:id="@+id/layout1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@+id/random_title"
        android:layout_marginTop="40dp"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/icon"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/icon"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="18sp"
            android:layout_marginTop="10dp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"/>
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        >
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp">

            <ImageView
                android:id="@+id/pc_share_icon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@mipmap/pc_share_icon"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_toEndOf="@+id/pc_share_icon"
                android:layout_centerVertical="true"
                android:layout_marginStart="15dp"/>

            <ImageView
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:src="@mipmap/right_gray"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp">

            <ImageView
                android:id="@+id/pc_share_icon2"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@mipmap/mine_support"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Give us a thumbs up"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_toEndOf="@+id/pc_share_icon2"
                android:layout_centerVertical="true"
                android:layout_marginStart="15dp"/>

            <ImageView
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:src="@mipmap/right_gray"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp">

            <ImageView
                android:id="@+id/pc_share_icon3"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@mipmap/mine_feedback"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opinion feedback"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_toEndOf="@+id/pc_share_icon3"
                android:layout_centerVertical="true"
                android:layout_marginStart="15dp"/>

            <ImageView
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:src="@mipmap/right_gray"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp">

            <ImageView
                android:id="@+id/pc_share_icon4"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@mipmap/setting_checkupdate"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check for updates"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_toEndOf="@+id/pc_share_icon4"
                android:layout_centerVertical="true"
                android:layout_marginStart="15dp"/>

            <ImageView
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:src="@mipmap/right_gray"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp">

            <ImageView
                android:id="@+id/pc_share_icon5"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@mipmap/setting_privacy"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privacy policy"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_toEndOf="@+id/pc_share_icon5"
                android:layout_centerVertical="true"
                android:layout_marginStart="15dp"/>

            <ImageView
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:src="@mipmap/right_gray"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp">

            <ImageView
                android:id="@+id/pc_share_icon6"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@mipmap/setting_agreement"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User protocol"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_toEndOf="@+id/pc_share_icon6"
                android:layout_centerVertical="true"
                android:layout_marginStart="15dp"/>

            <ImageView
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:src="@mipmap/right_gray"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>

        </RelativeLayout>



    </LinearLayout>


</RelativeLayout>